{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "atob",
  "rules": {
    "source_file": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "REPEAT",
              "content": {
                "type": "SEQ",
                "members": [
                  {
                    "type": "SYMBOL",
                    "name": "rule"
                  },
                  {
                    "type": "PATTERN",
                    "value": "(\\r?\\n)+"
                  }
                ]
              }
            },
            {
              "type": "SYMBOL",
              "name": "rule"
            }
          ]
        },
        {
          "type": "BLANK"
        }
      ]
    },
    "rule": {
      "type": "SEQ",
      "members": [
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "rule_keyword"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "lhs"
            },
            {
              "type": "BLANK"
            }
          ]
        },
        {
          "type": "STRING",
          "value": "="
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "SYMBOL",
              "name": "rhs"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "lhs": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "lhs_keyword"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "lhs_keyword"
            },
            {
              "type": "SYMBOL",
              "name": "text"
            }
          ]
        }
      ]
    },
    "rhs": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "rhs_keyword"
        },
        {
          "type": "SYMBOL",
          "name": "text"
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "rhs_keyword"
            },
            {
              "type": "SYMBOL",
              "name": "text"
            }
          ]
        }
      ]
    },
    "lhs_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "(start)"
        },
        {
          "type": "STRING",
          "value": "(end)"
        }
      ]
    },
    "rhs_keyword": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "(start)"
        },
        {
          "type": "STRING",
          "value": "(end)"
        },
        {
          "type": "STRING",
          "value": "(return)"
        }
      ]
    },
    "rule_keyword": {
      "type": "STRING",
      "value": "(once)"
    },
    "text": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[^\\r\\n#=()]+"
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "#.*"
      }
    }
  },
  "extras": [
    {
      "type": "SYMBOL",
      "name": "comment"
    },
    {
      "type": "PATTERN",
      "value": "(\\r?\\n)+"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}